cover transition-transform duration-500 group-hover:scale-105\" style=\"color:transparent\" src=\"/images/portfolio/project-08.webp\"/></button></li><li><button type=\"button\" class=\"group block w-full overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 focus-visible:outline-2 focus-visible:outline-accent-500\" aria-label=\"ดูรูปขยาย: ผลงานเจาะเสาเข็มของปรรณวัฒน์ วิศวกรรม โครงการที่ 9\"><img alt=\"ผลงานเจาะเสาเข็มของปรรณวัฒน์ วิศวกรรม โครงการที่ 9\" loading=\"lazy\" width=\"640\" height=\"480\" decoding=\"async\" data-nimg=\"1\" class=\"aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105\" style=\"color:transparent\" src=\"/images/portfolio/project-09.webp\"/></button></li><li><button type=\"button\" class=\"group block w-full overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 focus-visible:outline-2 focus-visible:outline-accent-500\" aria-label=\"ดูรูปขยาย: ผลงานเจาะเสาเข็มของปรรณวัฒน์ วิศวกรรม โครงการที่ 10\"><img alt=\"ผลงานเจาะเสาเข็มของปรรณวัฒน์ วิศวกรรม โครงการที่ 10\" loading=\"lazy\" width=\"640\" height=\"480\" decoding=\"async\" data-nimg=\"1\" class=\"aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105\" style=\"color:transparent\" src=\"/images/portfolio/project-10.webp\"/></button></li><li><button type=\"button\" class=\"group block w-full overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 focus-visible:outline-2 focus-visible:outline-accent-500\" aria-label=\"ดูรูปขยาย: ผลงานเจาะเสาเข็มของปรรณวัฒน์ วิศวกรรม โครงการที่ 11\"><img alt=\"ผลงานเจาะเสาเข็มของปรรณวัฒน์ วิศวกรรม โครงการที่ 11\" loading=\"lazy\" width=\"640\" height=\"480\" decoding=\"async\" data-nimg=\"1\" class=\"aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105\" style=\"color:transparent\" src=\"/images/portfolio/project-11.webp\"/></button></li><li><button type=\"button\" class=\"group block w-full overflow-hidden rounded-2xl border border-slate-200 bg-slate-100 focus-visible:outline-2 focus-visible:outline-accent-500\" aria-label=\"ดูรูปขยาย: ผลงานเจาะเสาเข็มของปรรณวัฒน์ วิศวกรรม โครงการที่ 12\"><img alt=\"ผลงานเจาะเสาเข็มของปรรณวัฒน์ วิศวกรรม โครงการที่ 12\" loading=\"lazy\" width=\"640\" height=\"480\" decoding=\"async\" data-nimg=\"1\" class=\"aspect-[4/3] w-full object-cover transition-transform duration-500 group-hover:scale-105\" style=\"color:transparent\" src=\"/images/portfolio/project-12.webp\"/></button></li></ul></section><section aria-labelledby=\"private-heading\"><h2 id=\"private-heading\" class=\"mb-8 text-2xl font-bold text-ink-900\">ผลงานภาคเอกชนและโรงงานอุตสาหกรรม</h2><ol class=\"grid gap-4 md:grid-cols-2\"><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">1</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 172 ต้น โครงการก่อสร้างอาคารโกดัง สูง 6 ชั้น</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท ผดุงวีอาร์ จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">2</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 32 ต้น โครงการก่อสร้างอาคารโกดัง สูง 3 ชั้น</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท ซีซีคอนสตรัคชั่นแอนด์ซัพพลาย จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">3</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 208 ต้น โครงการก่อสร้างโกดังริมแม่น้ำ</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท ซีวิลคอนสตรัคเจอรัลเอ็นจิเนีย จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">4</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะแบบเปียก 325 ต้น คอนโดพักอาศัย 8 ชั้น 2 อาคาร โครงการซอยคอนโด อ่อนนุช 55</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท สยามภามา จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">5</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 16 ต้น โครงการก่อสร้างสะพานข้ามทางรถไฟ อ.แก่งคอย</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท เอสเทคซีวิล แอนด์ คอนสตรัคชั่น จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">6</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะแบบเปียก 126 ต้น อาคารโรงเรียนปทุมคงคา สมุทรปราการ สูง 5 ชั้น 2 อาคาร</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท กรีนไลท์ อินเตอร์เนชั่นแนล จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">7</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 156 ต้น อาคารที่พักพนักงานการรถไฟ สูง 6 ชั้น</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท 3 เอ คอนสตรั๊คชั่นแอนด์ดีเวลลอปเมนท์ จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">8</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะเปียก 142 ต้น อาคารการรถไฟ สูง 5 ชั้น</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท 3 เอ คอนสตรั๊คชั่นแอนด์ดีเวลลอปเมนท์ จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">9</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 226 ต้น ทาวน์โฮม 4 ชั้น 6 หลัง ย่านเอกมัย</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท เอลิทซ์ ดีเวลลอปเมนท์ จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">10</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะชนิด 3 ขา ระบบเซฟตี้โรงงาน 122 ต้น งานปรับปรุงพื้นอาคารในโรงงาน บริษัท ทีโอเอ จำกัด</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท พลังไทย เอ็นจิเนียร์ แอนด์ คอนสตรั๊คชั่น จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">11</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะชนิด 3 ขา ระบบเซฟตี้โรงงาน 52 ต้น งานก่อสร้างถังบรรจุสารเคมี บ.ไทยกูลิโกะ นิคมอุตสาหกรรมบางกะดี่ ปทุมธานี</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท แก๊สคอนโทรล จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">12</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะรถเจาะระบบเซฟตี้โรงงาน 226 ต้น ฐานแทงค์บรรจุสารเคมี 4 ถัง บริษัท ไทยอีทอกซีเลท จำกัด นิคมอุตสาหกรรมมาบตาพุด</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท พงศธร เอ็นจิเนียริ่ง 1998 จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">13</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะชนิด 3 ขา ระบบเซฟตี้โรงงาน 12 ต้น งานก่อสร้างบายพาสไพพ์ระหว่างอาคาร บริษัท นิคคัน (ประเทศไทย) จำกัด นิคมอุตสาหกรรมโรจนะ</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท ไทยชิมิสึ จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">14</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะชนิด 3 ขา ระบบเซฟตี้โรงงาน 55 ต้น อาคารสำนักงาน 2 ชั้น การไฟฟ้าพระประแดง</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท วินิธร จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">15</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะชนิด 3 ขา ระบบเซฟตี้โรงงาน 100 ต้น งานปรับพื้นอาคารผลิต 2,500 ตร.ม. บริษัท สหไทยอาวา จำกัด นิคมอุตสาหกรรมกบินทร์บุรี</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท ไทยชิมิสึ จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">16</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะชนิด 3 ขา ระบบเซฟตี้โรงงาน 26 ต้น งานสร้างถังบำบัด บริษัท คาโอ อินดัสตรี จำกัด นิคมอุตสาหกรรมอมตะชลบุรี</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท อคาวาร่า นิชิฮาร่า คอปอเรชั่น จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">17</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะชนิด 3 ขา ระบบเซฟตี้โรงงาน 56 ต้น งานปรับพื้นอาคารพักสินค้า 1,000 ตร.ม. บริษัท มิตซูบิชิ กันยง จำกัด</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">ห้างหุ้นส่วน ทีซีอินเตอร์คอน 1999</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">18</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 172 ต้น โรงแรม 7 ชั้น ริมถนนพระราม 2 ปากซอย 32</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 60 ซม. ลึก 27 เมตร</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท อะเบ๊าท์ คอนสตรัคชั่น จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">19</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 88 ต้น อาคารพักอาศัย 6 ชั้น ซอยสุขุมวิท 101 ซอยปุณวิถี 28</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 50 ซม. ลึก 28 เมตร</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท ไตรโฮม จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">20</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 136 ต้น กำแพงกั้นดิน บ่อบำบัดน้ำเสีย รพ.สมเด็จพระบรมราชเทวี ณ ศรีราชา จ.ชลบุรี</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 60 ซม. ลึก 12 เมตร</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท อิตาเลี่ยนไทย ดีเวล็อปเมนท์ จำกัด (มหาชน)</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">21</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 82 ต้น บ่อบำบัดน้ำเสีย บริษัท พูแรค (ประเทศไทย) จำกัด นิคมอุตสาหกรรมเอเชีย อ.บ้านฉาง จ.ระยอง</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 50 ซม. ลึก 11 เมตร</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท อาควา นิชิฮาร่า คอร์ปอเรชั่น จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">22</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 28 ต้น ทางเชื่อมอาคารฝ่ายผลิต บริษัท วังน้อยเบเวอร์เรซ จำกัด (น้ำดื่มตราสิงห์) อ.วังน้อย จ.สระบุรี</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 50 ซม. ลึก 16 เมตร</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท ชาญนคร วิศวกรรม จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">23</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 98 ต้น บ้านพักอาศัย 4 บล็อค โครงการคาซ่า ซิตี้ ดอนเมือง</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 40 ซม. ลึก 20 เมตร (Wet Process)</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท ควอลิตี้ เฮ้าส์ จำกัด (มหาชน)</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">24</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 36 ต้น บ่อน้ำดี โครงการธนาซิตี้ กอล์ฟคลับ บางนา-ตราด กม.13 บางพลี สมุทรปราการ</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 50 ซม. ลึก 21 เมตร</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท แสงฤทธิ์ 2559 จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">25</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 136 ต้น ปรับปรุงอาคารผลิตยางรถยนต์ บริษัท มิชลิน จำกัด ถนนปู่เจ้าสมิงพราย พระประแดง สมุทรปราการ</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 35 ซม. ลึก 20 เมตร งานเซฟตี้ 100%</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท ไทยชิมิสึ จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">26</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">งานฐานเสาคมนาคม TRUE, DTAC, CAT ทำประจำทุกเดือน เดือนละกว่า 10 ฐาน รวมถึงงานบ้านลูกค้า งานวัด และอื่น ๆ</h3><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">ผู้ให้บริการโทรคมนาคมชั้นนำ</span></p></div></li></ol></section><section aria-labelledby=\"gov-heading\"><h2 id=\"gov-heading\" class=\"mb-8 text-2xl font-bold text-ink-900\">ผลงานกับหน่วยงานราชการ</h2><ol class=\"grid gap-4 md:grid-cols-2\"><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">1</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 86 ต้น อาคารเรียน รร.มัธยมวัดดุสิตตาราม เลียบใต้สะพานพระปิ่นเกล้า กรุงเทพฯ</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 35 ซม. ลึก 23 เมตร</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท เมคก้า ซีวิล จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">2</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 136 ต้น กำแพงกั้นดิน บ่อบำบัดน้ำเสีย รพ.สมเด็จพระบรมราชเทวี ณ ศรีราชา จ.ชลบุรี</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 60 ซม. ลึก 12 เมตร</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท อิตาเลี่ยนไทย ดีเวล็อปเมนท์ จำกัด (มหาชน)</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">3</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 156 ต้น อาคารที่พักพนักงานการรถไฟ สูง 6 ชั้น สถานีรถไฟลาดกระบัง กรุงเทพฯ</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 50 ซม. ลึก 20 เมตร</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท 3 เอ คอนสตรั๊คชั่นแอนด์ดีเวลลอปเมนท์ จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">4</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 56 ต้น อาคารสำนักงานการรถไฟ สูง 3 ชั้น สถานีรถไฟหัวลำโพง กรุงเทพฯ</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 40 ซม. ลึก 21 เมตร</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท สแกนดิเนเวีย คอนสตรั๊คชั่น จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">5</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 49 ต้น อาคารเรียน รร.วิศวกรรมรถไฟ สูง 2 ชั้น เขตจตุจักร กรุงเทพฯ</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 35 ซม. ลึก 20.50 เมตร</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">ห้างหุ้นส่วนจำกัด ทีพีพลัส</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">6</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 49 ต้น อาคารพิพิธภัณฑ์ รร.สตรีสมุทรปราการ ต.ปากน้ำ สมุทรปราการ</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 35 ซม. ลึก 21 เมตร</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท เมคก้า ซีวิล จำกัด</span></p></div></li><li class=\"flex gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition-colors hover:border-accent-400/50\"><span class=\"grid size-9 shrink-0 place-items-center rounded-xl bg-ink-950 text-sm font-bold text-accent-300\">7</span><div><h3 class=\"font-semibold leading-snug text-ink-900\">เสาเข็มเจาะ 16 ต้น สะพานข้ามทางรถไฟ อ.แก่งคอย</h3><p class=\"mt-1 text-sm text-slate-500\">เสาเข็มเจาะขนาด 60 ซม. ลึก 8 เมตร</p><p class=\"mt-1.5 text-sm text-slate-500\">ผู้ว่าจ้าง: <span class=\"font-medium text-slate-700\">บริษัท เอสเทคซีวิล แอนด์ คอนสตรัคชั่น จำกัด</span></p></div></li><li class=\"flex 